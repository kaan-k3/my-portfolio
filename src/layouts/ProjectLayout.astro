---
import "../styles/global.css";
import Beams from "../components/backgrounds/Beams.jsx";

const { title, subtitle, logo, logoAlt, logoClass = "", tags = [], context = "Team" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Kaan Keskindil</title>
  </head>

  <body class="bg-[#08090d] text-gray-100 min-h-screen font-body antialiased">

    <!-- Beams background (subtler on detail pages) -->
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[120vw] h-[120vh]">
        <div class="absolute inset-0 opacity-40
          [mask-image:radial-gradient(ellipse_70%_50%_at_50%_20%,black_0%,black_30%,transparent_70%)]">
          <Beams client:only="react" beamWidth={3} beamHeight={30} beamNumber={20}
            lightColor="#8ecae6" speed={1.2} noiseIntensity={1.5} scale={0.22} rotation={30} />
        </div>
      </div>
    </div>

    <!-- Sticky nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 nav-blur border-b border-white/[0.06] bg-[#08090d]/70">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-display font-bold text-sm tracking-wide text-white/80 hover:text-white transition-colors">
          KK
        </a>
        <div class="flex items-center gap-6">
          <a href="/#about" class="nav-link text-sm font-medium tracking-wide">About</a>
          <a href="/#experience" class="nav-link text-sm font-medium tracking-wide">Experience</a>
          <a href="/#projects" class="nav-link text-sm font-medium tracking-wide">Projects</a>
          <a href="/#skills" class="nav-link text-sm font-medium tracking-wide">Skills</a>
          <a href="/resume.pdf" target="_blank"
            class="ml-2 px-3.5 py-1.5 text-xs font-mono font-medium tracking-wide rounded-lg border border-white/10 text-white/60 hover:text-white hover:border-white/20 transition-all">
            Resume ↗
          </a>
        </div>
      </div>
    </nav>

    <!-- Page content -->
    <main class="relative z-10 max-w-5xl mx-auto px-6 pt-28 pb-20">

      <!-- Back link -->
      <a href="/#projects" class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/70 transition-colors mb-10">
        <span>←</span> Back to all projects
      </a>

      <!-- Project header -->
      <div class="flex items-start gap-4 mb-8">
        {logo && (
          <img src={logo} alt={logoAlt || title} class:list={["w-14 h-14 rounded-xl object-contain", logoClass]} />
        )}
        <div>
          <div class="flex items-center gap-3">
            <h1 class="font-display text-3xl sm:text-4xl font-700 text-white">{title}</h1>
            <span class:list={["context-tag", `context-tag--${context.toLowerCase()}`]}>{context}</span>
          </div>
          {subtitle && <p class="text-white/40 mt-1">{subtitle}</p>}
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {tags.map(tag => <span class="tech-tag">{tag}</span>)}
            </div>
          )}
        </div>
      </div>

      <div class="divider mb-10"></div>

      <!-- Content slot (the actual project content) -->
      <div class="project-content">
        <slot />
      </div>
    </main>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-white/[0.06] mt-20">
      <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs text-white/30 font-mono">© 2026 Kaan Keskindil</p>
        <div class="flex items-center gap-6">
          <a href="mailto:kkeskindil@mun.ca" class="text-xs text-white/40 hover:text-white/70 transition-colors font-mono">kkeskindil@mun.ca</a>
          <a href="https://linkedin.com/in/kaan-keskindil-46a13b256" target="_blank" class="text-xs text-white/40 hover:text-white/70 transition-colors font-mono">LinkedIn ↗</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      addEventListener("mousemove", (e) => {
        document.querySelectorAll(".glass-card").forEach((card) => {
          const r = card.getBoundingClientRect();
          card.style.setProperty("--mx", `${e.clientX - r.left}px`);
          card.style.setProperty("--my", `${e.clientY - r.top}px`);
        });
      }, { passive: true });
    </script>
  </body>
</html>