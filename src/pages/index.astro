---
import Layout from "../layouts/Layout.astro";
import PCBViewer from "../components/PCBViewer.jsx";
---

<Layout title="Kaan Keskindil — Electrical Engineering">

  <!-- HERO -->
  <section class="max-w-5xl mx-auto px-6 pt-36 pb-24">
    <div class="max-w-2xl">
      <p class="font-mono text-xs tracking-widest text-white/30 uppercase mb-4">
        Electrical Engineering · Memorial University
      </p>
      <h1 class="font-display text-5xl sm:text-6xl font-800 leading-[1.08] tracking-tight text-white">
        Kaan<br/>Keskindil
      </h1>
      <p class="mt-6 text-lg text-white/50 leading-relaxed max-w-xl font-light">
        Engineering student building at the intersection of embedded hardware,
        autonomous systems, and scientific computing. Currently seeking
        <span class="text-white/70">Sep–Dec 2026</span> co-op opportunities.
      </p>
      <div class="flex flex-wrap items-center gap-3 mt-8">
        <a href="#projects" class="px-5 py-2.5 text-sm font-medium rounded-xl bg-white/[0.07] border border-white/10 hover:bg-white/[0.12] hover:border-white/20 transition-all">
          View Projects
        </a>
        <a href="mailto:kkeskindil@mun.ca" class="px-5 py-2.5 text-sm font-medium text-white/50 hover:text-white/80 transition-colors">
          kkeskindil@mun.ca
        </a>
        <div class="flex items-center gap-3 ml-1">
          <a href="https://linkedin.com/in/kaan-keskindil-46a13b256" target="_blank" class="text-white/30 hover:text-white/70 transition-colors" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://github.com/kaan-k3" target="_blank" class="text-white/30 hover:text-white/70 transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="divider max-w-5xl mx-auto"></div>

  <!-- ABOUT -->
  <section id="about" class="max-w-5xl mx-auto px-6 py-20 fade-section">
    <p class="section-label">01 — About</p>
    <h2 class="section-title">Background</h2>
    <div class="max-w-2xl space-y-4">
      <p class="text-white/65 leading-relaxed">
        I'm an Electrical Engineering student at Memorial University with hands-on
        experience in autonomous systems research, embedded hardware design, and
        scientific software development. I work across the full stack of engineering —
        from designing PCBs and writing STM32 firmware to building C++/OpenGL
        desktop applications and deploying cloud-based trading infrastructure.
      </p>
      <p class="text-white/65 leading-relaxed">
        My work spans maritime autonomy research supervised by Dr. Wei Qiu,
        competitive engineering design teams, and a quantitative trading society
        where I direct data infrastructure. I'm driven by applying R&D to
        real-world engineering problems.
      </p>
      <div class="flex items-center gap-4 pt-2">
        <span class="text-xs font-mono text-white/25">Languages</span>
        <span class="text-sm text-white/50">English & Turkish (Native) · Spanish · French · Japanese</span>
      </div>
    </div>
  </section>

  <div class="divider max-w-5xl mx-auto"></div>

  <!-- EXPERIENCE -->
  <section id="experience" class="max-w-5xl mx-auto px-6 py-20">
    <div class="fade-section">
      <p class="section-label">02 — Experience</p>
      <h2 class="section-title">Work History</h2>
    </div>
    <div class="relative pl-6 stagger">
      <div class="timeline-line"></div>

      <div class="relative pb-12">
        <div class="timeline-dot"></div>
        <div class="glass-card p-6 ml-4">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
            <div class="flex items-start gap-3">
              <img src="/logos/mun-engineering.png" alt="MUN" class="w-9 h-9 rounded-md mt-0.5 object-contain bg-white/10 p-1" />
              <div>
                <h3 class="font-display font-600 text-base text-white/90">MASS Research Student</h3>
                <p class="text-sm text-white/40 mt-0.5">Ocean Engineering Research Center · Supervised by Dr. Wei Qiu</p>
              </div>
            </div>
            <span class="text-xs font-mono text-white/25 whitespace-nowrap shrink-0">Jan – May 2026</span>
          </div>
          <ul class="space-y-2 text-sm text-white/50 leading-relaxed">
            <li>Developed a <span class="text-white/70">C++/OpenGL</span> desktop application for ship hull visualization and hydrodynamic preprocessing — parsing IGES files to render NURBS surfaces, control nets, and surface normals in an interactive 3D viewer.</li>
            <li>Authored a large-scale research report on <span class="text-white/70">Maritime Autonomous Surface Ship</span> connectivity requirements for IMO and Transport Canada aligned frameworks.</li>
            <li>Designed and built an autonomous model vessel using Arduino and LiDAR with embedded C++ <span class="text-white/70">PID-based control</span> for wall tracking and obstacle avoidance.</li>
          </ul>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tech-tag">C++</span><span class="tech-tag">OpenGL</span><span class="tech-tag">NURBS</span><span class="tech-tag">Arduino</span><span class="tech-tag">LiDAR</span><span class="tech-tag">PID Control</span><span class="tech-tag">MATLAB</span>
          </div>
        </div>
      </div>

     <div class="relative pb-4">
  <div class="timeline-dot"></div>
  <div class="glass-card p-6 ml-4">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
      <div class="flex items-start gap-3">
        <img src="/logos/jvplabs.png" alt="JVPLabs" class="w-9 h-9 rounded-md mt-0.5 object-contain" />
        <div>
          <h3 class="font-display font-600 text-base text-white/90">Verification & Validation Student</h3>
          <p class="text-sm text-white/40 mt-0.5">JVPLabs</p>
        </div>
      </div>
      <span class="text-xs font-mono text-white/25 whitespace-nowrap shrink-0">May – Aug 2025</span>
    </div>
          <ul class="space-y-2 text-sm text-white/50 leading-relaxed">
            <li>Refactored Python-based data tools into a structured <span class="text-white/70">JupyterLab</span> application with modular components for log retrieval, processing, and visualization.</li>
            <li>Performed firmware updates and device configuration on <span class="text-white/70">Jetson Nano</span> through Linux.</li>
            <li>Designed and executed bring-up, stress, and regression tests on prototype medical hardware, validating power, I²C sensors, and IR-camera acquisition.</li>
            <li>Standardized FAT and end-of-line testing protocols, improving post-assembly quality control.</li>
          </ul>
          <div class="flex flex-wrap gap-1.5 mt-4">
            <span class="tech-tag">Python</span><span class="tech-tag">JupyterLab</span><span class="tech-tag">NumPy</span><span class="tech-tag">Pandas</span><span class="tech-tag">Linux</span><span class="tech-tag">Jetson Nano</span><span class="tech-tag">Hardware Testing</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="divider max-w-5xl mx-auto"></div>

  <!-- PROJECTS -->
  <section id="projects" class="max-w-5xl mx-auto px-6 py-20">
    <div class="fade-section">
      <p class="section-label">03 — Projects</p>
      <h2 class="section-title">Engineering Projects</h2>
    </div>

    <!-- Embedded & Hardware -->
    <div class="mb-14 fade-section">
      <div class="flex items-center gap-3 mb-8">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-amber-400/80"></span>
        <h3 class="font-display text-2xl font-700 text-white/85">Embedded & Hardware</h3>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 stagger">

        <!-- Paradigm card with PCB thumbnail -->
        <div class="glass-card group overflow-hidden">
          <a href="/projects/paradigm" class="block">
            <!-- PCB Thumbnail -->
            <div class="relative aspect-[16/9] overflow-hidden bg-[#0c0c14]">
              <img
                src="/projects/paradigm/control-pcb-thumb.png"
                alt="VCU PCB 3D Model"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
              <div class="absolute bottom-2 left-3 flex items-center gap-1.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="rgba(125,211,252,0.7)" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                  <path d="M2 17l10 5 10-5"/>
                  <path d="M2 12l10 5 10-5"/>
                </svg>
                <span class="text-[10px] font-mono text-sky-300/60">3D PCB Model</span>
              </div>
            </div>
            <div class="p-5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-start gap-3">
                  <img src="/logos/paradigm.png" alt="Paradigm" class="w-9 h-9 rounded-md mt-0.5 object-contain invert brightness-200" />
                  <div>
                    <h4 class="font-display font-600 text-white/85">Paradigm Engineering</h4>
                    <p class="text-xs font-mono text-white/30 mt-0.5">Electrical Team · Jan 2026 – Present</p>
                  </div>
                </div>
                <span class="context-tag context-tag--team">Team</span>
              </div>
              <p class="text-sm text-white/50 leading-relaxed mb-3">Designed STM32-based vehicle control and multi-rail power distribution PCBs in KiCad. Developed embedded C firmware for PWM-based motor braking control.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="tech-tag">STM32</span><span class="tech-tag">KiCad</span><span class="tech-tag">C</span><span class="tech-tag">PCB Design</span><span class="tech-tag">FDCAN</span><span class="tech-tag">JTAG</span>
              </div>
              <span class="detail-link group-hover:opacity-100">Click to view full details ›</span>
            </div>
          </a>
        </div>

        <div class="glass-card group overflow-hidden">
          <a href="/projects/eastern-edge" class="block">
            <div class="p-5">
              <div class="flex items-start justify-between mb-3">
                <div class="flex items-start gap-3">
                  <img src="/logos/eastern-edge.png" alt="Eastern Edge" class="w-12 h-9 rounded-md mt-0.5 object-contain" />
                  <div>
                    <h4 class="font-display font-600 text-white/85">Eastern Edge Robotics</h4>
                    <p class="text-xs font-mono text-white/30 mt-0.5">Software/Electrical · Sep 2024 – Present</p>
                  </div>
                </div>
                <span class="context-tag context-tag--team">Team</span>
              </div>
              <p class="text-sm text-white/50 leading-relaxed mb-3">Built mechanical assemblies for an underwater ROV. Investigating CANBus/RS-485 protocols and writing embedded C++ on Raspberry Pi for subsystem control.</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="tech-tag">C++</span><span class="tech-tag">CANBus</span><span class="tech-tag">RS-485</span><span class="tech-tag">Raspberry Pi</span><span class="tech-tag">OnShape</span>
              </div>
              <span class="detail-link group-hover:opacity-100">Click to view full details ›</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Scientific Computing & Research -->
    <div class="mb-14 fade-section">
      <div class="flex items-center gap-3 mb-8">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-sky-400/80"></span>
        <h3 class="font-display text-2xl font-700 text-white/85">Scientific Computing & Research</h3>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 stagger">
        <div class="glass-card group overflow-hidden sm:col-span-2">
          <a href="/projects/oerc" class="block p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-start gap-3">
                <img src="/logos/mun-engineering.png" alt="MUN" class="w-9 h-9 rounded-md mt-0.5 object-contain bg-white/10 p-1" />
                <div>
                  <h4 class="font-display font-600 text-white/85">OERC Research — Maritime Autonomy</h4>
                  <p class="text-xs font-mono text-white/30 mt-0.5">Ocean Engineering Research Center · Jan – May 2026</p>
                </div>
              </div>
              <span class="context-tag context-tag--work">Work</span>
            </div>
            <div class="sm:grid sm:grid-cols-2 sm:gap-6">
              <div>
                <p class="text-xs font-mono text-white/25 mb-1">Ship Hull Visualization</p>
                <p class="text-sm text-white/50 leading-relaxed mb-3">C++/OpenGL application for interactive 3D visualization of ship hull geometry. Parses IGES files to render NURBS surfaces. Integrated with a frequency-domain hydrodynamic solver for motion RAOs and drift forces.</p>
              </div>
              <div>
                <p class="text-xs font-mono text-white/25 mb-1">MASS Connectivity Research</p>
                <p class="text-sm text-white/50 leading-relaxed mb-3">Large-scale report evaluating Maritime Autonomous Surface Ship connectivity requirements across operational phases, aligned with IMO and Transport Canada frameworks.</p>
              </div>
            </div>
            <p class="text-xs font-mono text-white/25 mb-1">Autonomous Model Vessel</p>
            <p class="text-sm text-white/50 leading-relaxed mb-4">Designed hardware, wiring schematics, and embedded PID-based control for an autonomous vessel with wall tracking and obstacle avoidance using Arduino and LiDAR.</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <span class="tech-tag">C++</span><span class="tech-tag">OpenGL</span><span class="tech-tag">NURBS</span><span class="tech-tag">IGES</span><span class="tech-tag">Arduino</span><span class="tech-tag">LiDAR</span><span class="tech-tag">PID Control</span><span class="tech-tag">Research</span>
            </div>
            <span class="detail-link group-hover:opacity-100">Click to view full details ›</span>
          </a>
        </div>

        <div class="glass-card p-5">
          <div class="flex items-start justify-between mb-3">
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 rounded-md bg-sky-500/15 flex items-center justify-center text-sky-400 font-mono text-xs mt-0.5">Bio</div>
              <div>
                <h4 class="font-display font-600 text-white/85">Biology & Chemistry Research</h4>
                <p class="text-xs font-mono text-white/30 mt-0.5">Academic · 2024 – 2025</p>
              </div>
            </div>
            <span class="context-tag context-tag--personal">Personal</span>
          </div>
          <p class="text-sm text-white/50 leading-relaxed mb-3">Data-driven research using statistical hypothesis testing and meta-analysis to uncover patterns and validate experimental findings in biology and chemistry.</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            <span class="tech-tag">Statistics</span><span class="tech-tag">Meta-Analysis</span><span class="tech-tag">Python</span><span class="tech-tag">Research</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Data Infrastructure & Trading -->
    <div class="mb-14 fade-section">
      <div class="flex items-center gap-3 mb-8">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-emerald-400/80"></span>
        <h3 class="font-display text-2xl font-700 text-white/85">Data Infrastructure & Trading</h3>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 stagger">
        <div class="glass-card group overflow-hidden sm:col-span-2">
          <a href="/projects/mqs" class="block p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-start gap-3">
                <img src="/logos/mqs.png" alt="MQS" class="w-15 h-13 rounded-md mt-0.5 object-contain" />
                <div>
                  <h4 class="font-display font-600 text-white/85">MUN Quant Society</h4>
                  <p class="text-xs font-mono text-white/30 mt-0.5">Director, Data & Infrastructure · Sep 2025 – Present</p>
                </div>
              </div>
              <span class="context-tag context-tag--team">Team</span>
            </div>
            <div class="sm:grid sm:grid-cols-2 sm:gap-6">
              <p class="text-sm text-white/50 leading-relaxed mb-3">Directed development of end-to-end trading infrastructure including real-time ingestion pipelines, PostgreSQL storage, and GCP-deployed microservices powering HFT, backtesting, and sentiment-analysis.</p>
              <p class="text-sm text-white/50 leading-relaxed mb-3">Built scalable Python/SQL data tooling with CI/CD via GitHub Actions, NLP pipelines using PyTorch, and transformer hyperparameter tuning for low-latency market feed analysis.</p>
            </div>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <span class="tech-tag">Python</span><span class="tech-tag">PostgreSQL</span><span class="tech-tag">GCP</span><span class="tech-tag">PyTorch</span><span class="tech-tag">NLP</span><span class="tech-tag">GitHub Actions</span><span class="tech-tag">CI/CD</span><span class="tech-tag">Microservices</span>
            </div>
            <span class="detail-link group-hover:opacity-100">Click to view full details ›</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Other Projects -->
    <div class="fade-section">
      <div class="flex items-center gap-3 mb-8">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-violet-400/80"></span>
        <h3 class="font-display text-2xl font-700 text-white/85">Other Projects</h3>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 stagger">
        <div class="glass-card group overflow-hidden">
          <a href="/projects/siege-tracker" class="block p-5">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-md bg-violet-500/15 flex items-center justify-center text-violet-400 font-mono text-xs mt-0.5">R6</div>
                <div>
                  <h4 class="font-display font-600 text-white/85">Siege Tracker</h4>
                  <p class="text-xs font-mono text-white/30 mt-0.5">Personal Project · 2025</p>
                </div>
              </div>
              <span class="context-tag context-tag--personal">Personal</span>
            </div>
            <p class="text-sm text-white/50 leading-relaxed mb-3">Full-stack Python app combining API queries with Selenium scraping for real-time match stats. Flask dashboard, Discord bot, and Arduino OLED display for live metrics.</p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              <span class="tech-tag">Python</span><span class="tech-tag">Flask</span><span class="tech-tag">Selenium</span><span class="tech-tag">Discord.py</span><span class="tech-tag">Arduino</span>
            </div>
            <span class="detail-link group-hover:opacity-100">Click to view full details ›</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <div class="divider max-w-5xl mx-auto"></div>

  <!-- SKILLS -->
  <section id="skills" class="max-w-5xl mx-auto px-6 py-20 fade-section">
    <p class="section-label">04 — Skills</p>
    <h2 class="section-title mb-10">Technical Skills</h2>
    <div class="grid sm:grid-cols-2 gap-8">
      <div>
        <h3 class="text-xs font-mono text-white/30 uppercase tracking-wider mb-3">Languages & Frameworks</h3>
        <div class="flex flex-wrap gap-2">
          <span class="tech-tag">C++</span><span class="tech-tag">C</span><span class="tech-tag">Python</span><span class="tech-tag">MATLAB</span><span class="tech-tag">Bash</span><span class="tech-tag">SQL / PostgreSQL</span><span class="tech-tag">PyTorch</span><span class="tech-tag">NumPy</span><span class="tech-tag">Pandas</span>
        </div>
      </div>
      <div>
        <h3 class="text-xs font-mono text-white/30 uppercase tracking-wider mb-3">Hardware & Tools</h3>
        <div class="flex flex-wrap gap-2">
          <span class="tech-tag">PCB Design (KiCad)</span><span class="tech-tag">STM32</span><span class="tech-tag">Arduino</span><span class="tech-tag">Raspberry Pi</span><span class="tech-tag">PSPICE</span><span class="tech-tag">AutoCAD</span><span class="tech-tag">Git</span><span class="tech-tag">Linux</span><span class="tech-tag">OpenGL</span><span class="tech-tag">GCP</span>
        </div>
      </div>
      <div class="sm:col-span-2">
        <h3 class="text-xs font-mono text-white/30 uppercase tracking-wider mb-3">Domains</h3>
        <div class="flex flex-wrap gap-2">
          <span class="tech-tag">Autonomous Systems</span><span class="tech-tag">Maritime Engineering</span><span class="tech-tag">Embedded Systems</span><span class="tech-tag">Robotics & Control</span><span class="tech-tag">Scientific Computing</span><span class="tech-tag">Data Infrastructure</span>
        </div>
      </div>
    </div>
  </section>

</Layout>
